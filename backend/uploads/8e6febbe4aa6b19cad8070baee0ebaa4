"""Rock, Paper, Scissors game ."""
import random


choices = ('r', 'p', 's')
emojis = {
    'r': '🪨',
    'p': '📃',
    's': '✂️'
}
while True:
    response = input("Choose r: rock, p: paper or s: scissors.  ").lower()
    computer_choice = random.choice(choices)
    if response in choices:
        print(f" You chose {emojis[response]} ")
        print(f" Computer chose {emojis[computer_choice]}")
        if response == computer_choice:
            print(" It's a tie.")
        elif (response == 'r' and computer_choice == 's') or \
            (response == 's' and computer_choice == 'p') or \
                (response == 'p' and computer_choice == 'r'):
            print(" You won!")
        else:
            print(" Computer won.")
    else:
        print("Invalid response.")

    question = input("Do you want to play again? (Yes/No)  ").strip().lower()
    if question == 'yes':
        continue
    if question == 'no':
        print("Thanks for playing this game.")
        break
    else:
        print("Invalid response!")
